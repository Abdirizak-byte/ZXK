DATABASE_URL=postgresql://localhost:5432/clipping
YTDLP_PATH=yt-dlp
PORT=3001

# Max yt-dlp subprocesses allowed to run at once, system-wide (shared across
# shorts-sync, tiktok-sync, date-backfill, and manual account linking). Each
# process uses ~75-90MB RAM — keep this low on small instances. Default: 2.
MAX_YTDLP_PROCESSES=2

# Needed for the admin "Auto-File Clips" feature (AI matches clip
# thumbnails to clippers). Get a key at platform.openai.com/api-keys —
# this is a separate OpenAI account/billing, unrelated to Claude/Claude Code.
OPENAI_API_KEY=

# Gmail SMTP, used to email auto-generated credentials to approved clippers.
# Enable 2-Step Verification on the sending Gmail account, then generate an
# App Password at myaccount.google.com/apppasswords.
GMAIL_USER=
GMAIL_APP_PASSWORD=
# Base URL used in the credentials email's login link (set to the Render URL in production).
APP_URL=http://localhost:3001

# Production only (set automatically by render.yaml when deployed on Render):
# NODE_ENV=production   -> makes the session cookie HTTPS-only
# PGSSL=true             -> connects to Postgres over SSL

# Logins live in the `users` table (see schema.sql), not env vars.
# Create a user with a role of 'admin' (sees/manages everything) or 'client'
# (scoped to one row in `clients`, read-only). Generate a salt/hash with:
#   node -e "const c=require('crypto');const s=c.randomBytes(16).toString('hex');console.log('SALT='+s);console.log('HASH='+c.scryptSync('yourpassword',s,64).toString('hex'))"
